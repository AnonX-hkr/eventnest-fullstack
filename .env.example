# Copy this file to .env.local and fill in the values

# Backend API URL
# Development (Next.js proxy active): /api
# Production (direct Render URL): https://your-backend.onrender.com/api
NEXT_PUBLIC_API_URL=/api

# Stripe publishable key (optional — leave blank for demo/free mode)
# Get from: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
